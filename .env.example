# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/quickbill

# Auth
JWT_SECRET=change-me

# Google Sign-In (verify ID tokens on POST /api/auth/google)
GOOGLE_CLIENT_ID=

# Supabase Storage (company logo / signature → bucket "quickbill", public URL)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Public frontend (Stripe redirect URLs)
FRONTEND_URL=http://localhost:5173

# CORS: set to true only to confirm CORS is the issue (allows any Origin + credentials). Remove after debugging.
# CORS_DIAGNOSTIC=true

# Stripe — never commit real keys; webhook updates plan in DB only
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
